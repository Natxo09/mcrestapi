{
  "openapi": "3.1.0",
  "info": {
    "title": "MCRestAPI",
    "description": "REST API for monitoring and controlling Minecraft servers. Authentication uses a Bearer API key by default; it can be disabled (auth.enabled = false in the config) to delegate authentication to a reverse proxy.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:{{PORT}}",
      "description": "Local Minecraft Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/server": {
      "get": {
        "tags": ["Server"],
        "summary": "Get server information",
        "description": "Returns server stats. Use the `fields` parameter to request specific sections only.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of sections to include: info, tps, memory, cpu, players, properties, resource_pack. Returns all if omitted.",
            "schema": {
              "type": "string",
              "example": "tps,memory,cpu"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Server information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/server/icon": {
      "get": {
        "tags": ["Server"],
        "summary": "Get server icon",
        "description": "Returns the server icon (server-icon.png) as a PNG image. Does not require authentication.",
        "security": [],
        "responses": {
          "200": {
            "description": "Server icon PNG",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "No server icon configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/mods": {
      "get": {
        "tags": ["Mods"],
        "summary": "Get installed mods",
        "description": "Returns a list of all Fabric mods loaded on the server with their metadata.",
        "responses": {
          "200": {
            "description": "Mods list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/world": {
      "get": {
        "tags": ["World"],
        "summary": "Get world information",
        "description": "Returns global world data (shared across dimensions) and per-dimension stats. Use the `fields` parameter to request specific sections.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of sections: global, dimensions. Returns all if omitted.",
            "schema": {
              "type": "string",
              "example": "global"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "World information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorldResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server tick timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/keys": {
      "get": {
        "tags": ["Admin"],
        "summary": "List API keys",
        "description": "Returns all API keys (without hashes). Requires master key.",
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "keys": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ApiKeyInfo" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden: master key required" }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Create API key",
        "description": "Creates a new API key. The key value is returned once and cannot be retrieved again.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "permissions"],
                "properties": {
                  "name": { "type": "string", "example": "Dashboard" },
                  "permissions": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["server.read", "players.read"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Key created (key shown once)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyCreated" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "Update API key",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "permissions": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Key updated" },
          "404": { "description": "Key not found" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Revoke API key",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Key revoked" },
          "404": { "description": "Key not found" }
        }
      }
    },
    "/api/admin/cors": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get CORS configuration",
        "responses": {
          "200": {
            "description": "CORS settings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CorsConfig" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Add CORS origin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["origin"],
                "properties": {
                  "origin": { "type": "string", "example": "https://example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Origin added" }
        }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "Toggle CORS enabled/disabled",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "CORS toggled" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Remove CORS origin",
        "parameters": [
          { "name": "origin", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Origin removed" },
          "404": { "description": "Origin not found" }
        }
      }
    },
    "/api/admin/settings": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get server settings",
        "responses": {
          "200": {
            "description": "Current settings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Settings" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "Update settings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "swagger_enabled": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Settings updated" }
        }
      }
    },
    "/api/chat": {
      "get": {
        "tags": ["Chat"],
        "summary": "Get event history",
        "description": "Returns recent server events (chat, join, leave, death, game messages). Use `limit` and `type` to filter.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Max events to return (default 50, max 200)",
            "schema": { "type": "integer", "example": 50 }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Comma-separated event types: chat, command, join, leave, death, game",
            "schema": { "type": "string", "example": "chat,join,leave" }
          }
        ],
        "responses": {
          "200": {
            "description": "Event history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer", "example": 3 },
                    "events": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ServerEvent" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/events/stream": {
      "get": {
        "tags": ["Events"],
        "summary": "Server-Sent Events stream",
        "description": "Real-time event stream via SSE. Connect with EventSource or any SSE-compatible client. Events are sent as `event: <type>\\ndata: <json>\\n\\n`.",
        "parameters": [
          {
            "name": "types",
            "in": "query",
            "required": false,
            "description": "Comma-separated event types to subscribe to. All if omitted.",
            "schema": { "type": "string", "example": "chat,death" }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/command": {
      "post": {
        "tags": ["Command"],
        "summary": "Execute server command",
        "description": "Executes a Minecraft command on the server. Requires `command.execute` permission.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["command"],
                "properties": {
                  "command": { "type": "string", "example": "say Hello World" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "output": { "type": "string", "example": "" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden: missing permission" }
        }
      }
    },
    "/api/players": {
      "get": {
        "tags": ["Players"],
        "summary": "Get online players",
        "description": "Returns a list of all online players with their current stats and position.",
        "responses": {
          "200": {
            "description": "Player list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server tick timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key from config/mcrestapi.json (e.g. mcsapi_abc123...)"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "ServerResponse": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "example": "1.21.11"
          },
          "motd": {
            "type": "string",
            "example": "A Minecraft Server"
          },
          "server_port": {
            "type": "integer",
            "example": 25565
          },
          "online_mode": {
            "type": "boolean",
            "example": true
          },
          "uptime_seconds": {
            "type": "integer",
            "example": 86400
          },
          "tps": {
            "type": "number",
            "example": 20.0
          },
          "mspt": {
            "type": "number",
            "example": 12.5
          },
          "memory": {
            "type": "object",
            "properties": {
              "used_mb": { "type": "integer", "example": 2048 },
              "total_mb": { "type": "integer", "example": 4096 },
              "max_mb": { "type": "integer", "example": 8192 },
              "free_mb": { "type": "integer", "example": 2048 },
              "usage_percent": { "type": "number", "example": 50.0 }
            }
          },
          "cpu": {
            "type": "object",
            "properties": {
              "system_load": { "type": "number", "example": 11.47 },
              "available_processors": { "type": "integer", "example": 8 },
              "process_load": { "type": "number", "example": 15.2 }
            }
          },
          "players": {
            "type": "object",
            "properties": {
              "online": { "type": "integer", "example": 5 },
              "max": { "type": "integer", "example": 20 }
            }
          },
          "resource_pack": {
            "nullable": true,
            "type": "object",
            "properties": {
              "url": { "type": "string", "example": "https://example.com/pack.zip" },
              "hash": { "type": "string", "example": "abc123def456" },
              "required": { "type": "boolean", "example": true },
              "prompt": { "type": "string", "nullable": true, "example": "Please accept the resource pack" }
            }
          },
          "properties": {
            "type": "object",
            "properties": {
              "gamemode": { "type": "string", "example": "survival" },
              "difficulty": { "type": "string", "example": "easy" },
              "hardcore": { "type": "boolean", "example": false },
              "allow_flight": { "type": "boolean", "example": false },
              "whitelist": { "type": "boolean", "example": false },
              "enforce_whitelist": { "type": "boolean", "example": false },
              "enforce_secure_profile": { "type": "boolean", "example": true },
              "max_world_size": { "type": "integer", "example": 29999984 },
              "spawn_protection": { "type": "integer", "example": 16 },
              "view_distance": { "type": "integer", "example": 10 },
              "simulation_distance": { "type": "integer", "example": 10 },
              "max_tick_time": { "type": "integer", "example": 60000 }
            }
          }
        }
      },
      "WorldResponse": {
        "type": "object",
        "properties": {
          "global": { "$ref": "#/components/schemas/WorldGlobal" },
          "dimensions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Dimension" }
          }
        }
      },
      "WorldGlobal": {
        "type": "object",
        "description": "Shared world data (same across all dimensions)",
        "properties": {
          "seed": { "type": "integer", "example": 123456789 },
          "time": {
            "type": "object",
            "properties": {
              "game_time": { "type": "integer", "example": 72000 },
              "day_time": { "type": "integer", "example": 6000 },
              "day_count": { "type": "integer", "example": 42 }
            }
          },
          "weather": {
            "type": "object",
            "properties": {
              "raining": { "type": "boolean", "example": false },
              "thundering": { "type": "boolean", "example": false }
            }
          },
          "difficulty": { "type": "string", "example": "easy" },
          "difficulty_locked": { "type": "boolean", "example": false },
          "hardcore": { "type": "boolean", "example": false },
          "pvp": { "type": "boolean", "example": true },
          "spawn": {
            "type": "object",
            "properties": {
              "x": { "type": "integer", "example": 0 },
              "y": { "type": "integer", "example": 64 },
              "z": { "type": "integer", "example": 0 }
            }
          }
        }
      },
      "Dimension": {
        "type": "object",
        "description": "Per-dimension data",
        "properties": {
          "name": { "type": "string", "example": "minecraft:overworld" },
          "sea_level": { "type": "integer", "example": 63 },
          "flat": { "type": "boolean", "example": false },
          "loaded_chunks": { "type": "integer", "example": 625 },
          "entity_count": { "type": "integer", "example": 1520 },
          "world_border": {
            "type": "object",
            "properties": {
              "size": { "type": "number", "example": 59999968.0 },
              "center_x": { "type": "number", "example": 0.0 },
              "center_z": { "type": "number", "example": 0.0 }
            }
          }
        }
      },
      "ServerEvent": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["chat", "command", "join", "leave", "death", "game"], "example": "chat" },
          "player": { "type": "string", "nullable": true, "example": "Steve" },
          "content": { "type": "string", "example": "Hello everyone!" },
          "timestamp": { "type": "string", "format": "date-time", "example": "2026-03-07T22:30:00Z" }
        }
      },
      "ApiKeyInfo": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "dk_a1b2c3d4" },
          "name": { "type": "string", "example": "Dashboard" },
          "permissions": { "type": "array", "items": { "type": "string" }, "example": ["server.read", "players.read"] },
          "created_at": { "type": "string", "example": "2026-03-06T22:00:00Z" }
        }
      },
      "ApiKeyCreated": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "dk_a1b2c3d4" },
          "name": { "type": "string", "example": "Dashboard" },
          "key": { "type": "string", "example": "mcsapi_a7f2b9c1e4d8..." },
          "permissions": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string" },
          "warning": { "type": "string", "example": "Save this key now. It will not be shown again." }
        }
      },
      "CorsConfig": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "example": false },
          "allowed_origins": { "type": "array", "items": { "type": "string" }, "example": ["https://example.com"] }
        }
      },
      "Settings": {
        "type": "object",
        "properties": {
          "port": { "type": "integer", "example": 8080 },
          "bind_address": { "type": "string", "example": "127.0.0.1" },
          "max_connections": { "type": "integer", "example": 50 },
          "swagger_enabled": { "type": "boolean", "example": true }
        }
      },
      "ModsResponse": {
        "type": "object",
        "properties": {
          "count": { "type": "integer", "example": 12 },
          "mods": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Mod" }
          }
        }
      },
      "Mod": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "mcrestapi" },
          "name": { "type": "string", "example": "MCRestAPI" },
          "version": { "type": "string", "example": "1.1.0" },
          "description": { "type": "string", "example": "REST API for Minecraft servers" },
          "authors": { "type": "array", "items": { "type": "string" }, "example": ["natxo"] },
          "license": { "type": "array", "items": { "type": "string" }, "example": ["MIT"] },
          "environment": { "type": "string", "enum": ["SERVER", "CLIENT", "UNIVERSAL"], "example": "SERVER" },
          "contact": {
            "type": "object",
            "properties": {
              "homepage": { "type": "string" },
              "sources": { "type": "string" },
              "issues": { "type": "string" }
            }
          }
        }
      },
      "PlayersResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "example": 2
          },
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Player"
            }
          }
        }
      },
      "Player": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Steve" },
          "uuid": { "type": "string", "example": "069a79f4-44e9-4726-a5be-fca90e38aaf5" },
          "health": { "type": "number", "example": 20.0 },
          "food_level": { "type": "integer", "example": 18 },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number", "example": 100.5 },
              "y": { "type": "number", "example": 64.0 },
              "z": { "type": "number", "example": -200.3 }
            }
          },
          "dimension": { "type": "string", "example": "minecraft:overworld" },
          "ping_ms": { "type": "integer", "example": 45 },
          "game_mode": { "type": "string", "example": "survival" },
          "is_op": { "type": "boolean", "example": false },
          "skin_head_url": { "type": "string", "example": "https://mc-heads.net/avatar/069a79f4-44e9-4726-a5be-fca90e38aaf5/64" }
        }
      }
    }
  }
}
